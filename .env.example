# Copy this file to .env and fill in your keys. Never commit .env.

# Clerk (required for per-user API key storage). From https://dashboard.clerk.com → API Keys.
# Backend needs BOTH: Secret Key and Publishable Key (same app as frontend).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Secret used to encrypt Gemini API keys at rest in the database. Min 16 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_SECRET=

# Optional: Gemini API key. Only used when Clerk is not configured (fallback: send apiKey in request body).
# GEMINI_API_KEY=

# Optional: Gemini model (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: server port (default 3001)
# PORT=3001

# Google OAuth (Gmail connection + JobStreet Google login helper)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://your-backend.example.com/api/email/gmail/callback
# GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile
# JOBSTREET_GOOGLE_LOGIN_URL=https://www.jobstreet.com.sg/en/login

# Note: Web search uses DuckDuckGo HTML scraping (free, no API key needed)
