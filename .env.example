# Copy this file to .env and fill in your keys. Never commit .env.

# Gemini API key (for /api/chat). Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Gemini model (default gemini-2.5-flash; free tier)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: server port (default 3001)
# PORT=3001
