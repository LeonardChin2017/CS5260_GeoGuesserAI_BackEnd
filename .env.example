# Copy this file to .env and fill in your keys. Never commit .env.

# Gemini API key. Backend uses this for chat; can also send an encoded version to frontend via GET /api/gemini-key.
GEMINI_API_KEY=

# Secret used to encrypt the API key when sending to frontend (GET /api/gemini-key). Min 16 chars.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GEMINI_KEY_ENCODING_SECRET=

# Optional: Gemini model (default gemini-2.5-flash; free tier)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: server port (default 3001)
# PORT=3001
