# Copy this file to .env and fill in your keys. Never commit .env.

# Gemini API key. Get one at https://aistudio.google.com/app/api-keys.
GEMINI_API_KEY=
# Gemini model (default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# server port
PORT=3001
# Google Maps key for Street View Static API. Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# Comma-separated frontend origins allowed to call backend from browsers.
# Example: CORS_ALLOW_ORIGINS=https://your-app.vercel.app,https://app.example.com
# For local frontend development:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGINS=
