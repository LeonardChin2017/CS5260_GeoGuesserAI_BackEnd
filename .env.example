# Copy this file to .env and fill in your keys. Never commit .env.

# Gemini API key. Get one at https://aistudio.google.com/app/api-keys.
GEMINI_API_KEY=
# Gemini model (default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# server port
PORT=3001
# Google Maps key for Street View Static API. Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=