# Copy this file to .env and fill in your keys. Never commit .env.

# Clerk (required for per-user API key storage). From https://dashboard.clerk.com → API Keys.
# Backend needs BOTH: Secret Key and Publishable Key (same app as frontend).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Secret used to encrypt API keys at rest in the database. Min 16 chars.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
ENCRYPTION_SECRET=

# Optional: Gemini API key. Only used when Clerk is not configured (fallback: send apiKey in request body).
# GEMINI_API_KEY=
# Optional: DeepSeek API key. Only used when Clerk is not configured (fallback: send apiKey in request body).
# DEEPSEEK_API_KEY=

# Optional: Gemini model (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# Optional: DeepSeek model (default deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# Optional: server port (default 3001)
# PORT=3001

# Google Maps key for Street View Static API (used by GeoGuess sandbox frame rendering)
GOOGLE_MAPS_API_KEY=

# Note: this backend only supports question generation and PDF output.
