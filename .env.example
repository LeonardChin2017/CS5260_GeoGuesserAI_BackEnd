# Copy this file to .env and fill in your keys. Never commit .env.

# Gemini API key. Only used when Clerk is not configured (fallback: send apiKey in request body).
GEMINI_API_KEY=
# Gemini model (default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Optional: server port (default 3001)
PORT=3001
# Google Maps key for Street View Static API (used by GeoGuess sandbox frame rendering)
GOOGLE_MAPS_API_KEY=