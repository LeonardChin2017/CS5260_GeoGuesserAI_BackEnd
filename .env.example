# Copy this file to .env and fill in your keys. Never commit .env.

# Clerk (required for per-user API key storage). Get Secret Key: https://dashboard.clerk.com → API Keys.
# When set: user saves Gemini key in Settings → backend stores it encrypted in DB; chat uses key by userId.
CLERK_SECRET_KEY=

# Secret used to encrypt Gemini API keys at rest in the database. Min 16 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_SECRET=

# Optional: Gemini API key. Only used when Clerk is not configured (fallback: send apiKey in request body).
# GEMINI_API_KEY=

# Optional: Gemini model (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: server port (default 3001)
# PORT=3001
